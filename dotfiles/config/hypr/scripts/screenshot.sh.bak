#!/usr/bin/env bash

# generate timestamp for screenshot filename
time=$(date +%d-%b-%y_%Ih%Mm%Ss%p)

# screenshot save directory
dir="$(xdg-user-dir)/pictures/screenshots"

# final screenshot filename
file="screenshot-${time}.png"

# send notification using qs IPC
notify() {
  qs -c noctalia-shell ipc call toast send "$1"
}

# get currently focused monitor name from Hyprland
get_active_monitor() {
  hyprctl monitors -j | jq -r '.[] | select(.focused) | .name'
}

# notification shown after screenshot is saved
notify_saved() {
  notify '{
    "title": "Screenshot",
    "body": "Screenshot saved and copied to clipboard.",
    "icon": "screenshot"
  }'
}

# countdown before taking screenshot
countdown() {
  local sec
  for ((sec = $1; sec > 0; sec--)); do
    notify "{
      \"title\": \"Screenshot\",
      \"body\": \"Taking shot in: $sec\",
      \"icon\": \"screenshot\",
      \"duration\": 500
    }"
    sleep 1
  done
}

# main screenshot function
# handles both full monitor screenshots and geometry screenshots
take_shot() {
  local monitor
  monitor=$(get_active_monitor)

  # if geometry (-g) is passed, don't use monitor restriction
  # geometry coordinates are already global
  if [[ "$1" == "-g" ]]; then
    grim "$@" - | tee "$dir/$file" | wl-copy
  else
    grim -o "$monitor" - | tee "$dir/$file" | wl-copy
  fi

  # send saved notification
  notify_saved
}

# take screenshot immediately
shot_now() {
  take_shot
}

# take screenshot after 5 second delay
shot_5() {
  countdown 5
  take_shot
}

# take screenshot after 10 second delay
shot_10() {
  countdown 10
  take_shot
}

# screenshot currently active window
shot_active() {
  # get window position and size using Hyprland JSON output
  read -r x y w h <<<$(hyprctl activewindow -j | jq -r '.at + .size | @sh' | tr -d "'")

  # pass geometry to grim
  take_shot -g "${x},${y} ${w}x${h}"
}

# screenshot selected region using slurp
shot_area() {
  take_shot -g "$(slurp)"
}

# ensure screenshot directory exists
if [[ ! -d "$dir" ]]; then
  mkdir -p "$dir"
fi

# handle command line arguments
case "$1" in
--now)
  shot_now
  ;;
--in5)
  shot_5
  ;;
--in10)
  shot_10
  ;;
--active)
  shot_active
  ;;
--area)
  shot_area
  ;;
*)
  echo "Options: --now --in5 --in10 --active --area"
  ;;
esac
